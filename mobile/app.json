{
  "expo": {
    "name": "PortaSplit Monitor",
    "slug": "portasplit-monitor",
    "version": "1.5.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "portasplit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.portasplit.monitor",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "fr.portasplit.monitor.refresh"
        ],
        "NSUserNotificationsUsageDescription": "PortaSplit vous alerte quand le climatiseur est en stock près de chez vous ou disponible en livraison."
      }
    },
    "android": {
      "package": "fr.portasplit.monitor",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2563eb",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#2563eb"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563eb",
          "sounds": []
        }
      ],
      "expo-background-fetch"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6810e22d-4689-4046-9b7d-31fd84c3c88c"
      }
    },
    "owner": "dorian172"
  }
}
