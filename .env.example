# Copier ce fichier en .env et remplir les valeurs

# Telegram — créer un bot via @BotFather, récupérer le chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnel : webhook Discord (laisser vide pour désactiver)
DISCORD_WEBHOOK_URL=

# Optionnel : notifications push via ntfy.sh (choisissez un topic unique/secret)
# Installez l'app ntfy sur votre téléphone et abonnez-vous au même topic
NTFY_TOPIC=

# Intervalle entre deux vérifications (minutes) — GitHub Actions : 10 min
CHECK_INTERVAL_MINUTES=10

# Double verification du stock avant alerte (2 lectures espacées de 3 s)
CONFIRM_STOCK=true

# Nombre de tentatives par canal de notification (Telegram, etc.)
NOTIFY_RETRIES=3

# Surveillance : magasin < LOCAL_RADIUS_KM autour de POSTAL_CODE OU livraison vers ce code postal
POSTAL_CODE=33000
LOCAL_RADIUS_KM=100

# Rapport quotidien « le moniteur tourne toujours » (apres HEARTBEAT_HOUR)
HEARTBEAT_ENABLED=true
HEARTBEAT_HOUR=18
HEARTBEAT_TIMEZONE=Europe/Paris
